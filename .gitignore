# ── Credentials — never commit ────────────────────────────────────────────────
config/hackerone_credentials.csv
config/*.csv
config/*.key
config/*.secret
auth.yaml
**/auth.yaml

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/

# ── Tests ─────────────────────────────────────────────────────────────────────
tests/

# ── Scan output — directories created by ScanOutputManager in cwd ─────────────
# Pattern: {target}-scan-{timestamp}/  e.g. airbnb.com-scan-30-Jun-2026_14-17-43/
*-scan-*/
test/
testscan/
scans/
**/scans/

# ── Operational output files (reports, exports, raw tool output) ──────────────
findings.db
findings.json
# JSON exports at repo root only (preserves docs/ and .devcontainer/ JSON)
/*.json
# Text output dumps at repo root
/*.txt
# HTML reports at repo root (preserves docs/manual/index.html)
/*.html
reports/
*.log

# ── Audit notes ───────────────────────────────────────────────────────────────
audit/
**/audit/

# ── Personal notes / drafts ───────────────────────────────────────────────────
BURP_INSPIRATION_NOTES.md
BURP_DEFERRED_TODO.md
notes for improvement/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
